# Public (browser-safe) — required for auth, storage, and the app shell
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Canonical site URL for SEO metadata, sitemap, OAuth redirectTo, and social previews.
# Must be set at BUILD time on Vercel (NEXT_PUBLIC_*).
NEXT_PUBLIC_SITE_URL=https://www.readways.com

# Sentry error monitoring (closed beta / production)
# Client DSN can be public; server DSN can reuse same value.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Optional release metadata and source-map upload (CI/Vercel)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Explain prefetch for visible reader paragraphs (set to 0 to disable)
# NEXT_PUBLIC_EXPLAIN_PREFETCH=0

# Server-only — never prefix with NEXT_PUBLIC_
OPENAI_API_KEY=your-openai-api-key
# Optional model override (defaults to gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Do NOT set these as NEXT_PUBLIC_* — they must stay on the server only:
# SUPABASE_SERVICE_ROLE_KEY=
