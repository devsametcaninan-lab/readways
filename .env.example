# Public (browser-safe) — required for auth, storage, and the app shell
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Canonical site URL for SEO metadata, sitemap, and social previews (production)
NEXT_PUBLIC_SITE_URL=https://readways.app

# Server-only — never prefix with NEXT_PUBLIC_
OPENAI_API_KEY=your-openai-api-key
# Optional model override (defaults to gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Do NOT set these as NEXT_PUBLIC_* — they must stay on the server only:
# SUPABASE_SERVICE_ROLE_KEY=
